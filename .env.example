# Copy this file to .env and fill in your values.
# Without Supabase credentials the scraper runs in dry-run mode and prints
# listings to stdout instead of storing them.

# Supabase project URL, e.g. https://abcdefghijkl.supabase.co
SUPABASE_URL=

# Supabase service role key (Project Settings -> API -> service_role).
# KEEP THIS SECRET - it bypasses row level security. Never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated cities to scrape. Each site is only scraped for the cities
# it supports. Supported out of the box: Amsterdam, Rotterdam, The Hague,
# Utrecht, Groningen, Maastricht, Leiden, Delft, Eindhoven, Tilburg,
# Enschede, Hengelo, Beetsterzwaag, Gorredijk
CITIES=Amsterdam,Rotterdam,The Hague,Utrecht,Groningen

# Set to 1 to force dry-run mode even with Supabase credentials configured
#DRY_RUN=1
